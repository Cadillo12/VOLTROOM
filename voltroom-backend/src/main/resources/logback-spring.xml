<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Directorio y nombre del archivo de logs -->
    <property name="LOGS" value="./logs" />

    <!-- Appender para la consola -->
    <appender name="Console"
              class="ch.qos.logback.core.ConsoleAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
            <Pattern>
                %black(%d{ISO8601}) %highlight(%-5level) [%blue(%t)] %yellow(%C{1}): %msg%n%throwable
            </Pattern>
        </layout>
    </appender>

    <!-- Appender para archivo con Rolling (para guardar historial) -->
    <appender name="RollingFile"
              class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS}/voltroom-logger.log</file>
        <encoder
                class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <Pattern>%d %p %C{1} [%t] %m%n</Pattern>
        </encoder>

        <rollingPolicy
                class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- rollover daily and when the file reaches 10 MegaBytes -->
            <fileNamePattern>${LOGS}/archived/voltroom-logger-%d{yyyy-MM-dd}.%i.log
            </fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy
                    class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <!-- Perfil para entorno de desarrollo -->
    <springProfile name="dev | default">
        <root level="INFO">
            <appender-ref ref="Console" />
            <appender-ref ref="RollingFile" />
        </root>
        <logger name="com.voltroom" level="DEBUG" additivity="false">
            <appender-ref ref="Console" />
            <appender-ref ref="RollingFile" />
        </logger>
    </springProfile>

    <!-- Perfil para entorno de producción -->
    <springProfile name="prod">
        <root level="ERROR">
            <appender-ref ref="Console" />
            <appender-ref ref="RollingFile" />
        </root>
        <logger name="com.voltroom" level="INFO" additivity="false">
            <appender-ref ref="Console" />
            <appender-ref ref="RollingFile" />
        </logger>
    </springProfile>

</configuration>
